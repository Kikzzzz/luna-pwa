# Luna PWA — .gitignore
# ============================================================
# The anon key in supabase-config.js IS safe to commit.
# The files listed here are ones you should NEVER commit.
# ============================================================

# If you ever switch to environment variables or a build step
.env
.env.local
.env.production
.env.*

# Never commit the Supabase service_role key anywhere
# (it bypasses all RLS — treat it like a root password)
service-role-key.txt
secrets.txt
secrets.json

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Node (if you ever add a build step)
node_modules/
